[bot]
# Supported values: fi, en
language = fi
enabled = true

[discord]
# Local production config only. Do not commit real tokens.
token =
# Required with --run-discord/--preflight. Comma-separated Discord server ids.
allowed_guild_ids =
# Optional channel allowlist inside allowed guilds. Empty means all channels in allowed guilds.
allowed_channel_ids =
# DMs are rejected by runtime policy. This legacy field must not be used to enable DMs.
allow_direct_messages = false

[openai]
# Local production config only. Do not commit real API keys.
api_key =
model = gpt-5.5
max_tokens = 500
timeout_s = 180

[storage]
database_path = data/aimo.sqlite3
artifact_path = artifacts
raw_gpx_path = data/raw_gpx

[public_artifacts]
# Optional public delivery path for rendered files that are too large for Discord attachments.
# The directory should be served by nginx and pruned externally, for example after 24h.
path =
base_url =
max_discord_attachment_bytes = 8388608
retention_hours = 24

[admin]
# Comma-separated Discord user ids.
user_ids =

[limits]
max_attachment_size_bytes = 26214400

[history]
retention_days = 365

[debug]
enabled = true

[maps]
# osm = local OSM tile fallback. maptiler = MapTiler raster tile base maps when maptiler_api_key is configured.
provider = osm
# Prefer MAPTILER_API_KEY environment variable or a local untracked config override.
maptiler_api_key =
maptiler_map_id = streets-v4
timeout_s = 10

[weather]
# open_meteo = live forecast for dated route-time estimates. none disables live weather and uses seasonal fallback.
enabled = true
provider = open_meteo
timeout_s = 8
